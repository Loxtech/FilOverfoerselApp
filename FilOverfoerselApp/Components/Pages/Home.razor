@page "/"
@using FilOverfoerselApp.Services
@using System.Security.Cryptography
@inject IAesHandler AesHandler
@inject IAesGcmHandler AesGcmHandler
@rendermode InteractiveServer

<PageTitle>Fil overførsel app</PageTitle>

<h3>Fil overførsel app</h3>

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <div class="alert @_statusClass mt-3">@_statusMessage</div>
}

<div class="mt-3" style="max-width:420px">
    <div class="mb-3">
        <div class="form-check">
            <input type="radio" class="form-check-input" id="rsa"
                   checked="@(_mode == EncryptMode.Rsa)"
                   @onchange="() => _mode = EncryptMode.Rsa" />
            <label class="form-check-label" for="rsa">Encrypt with RSA public key</label>
        </div>
        <div class="form-check">
            <input type="radio" class="form-check-input" id="gcm"
                   checked="@(_mode == EncryptMode.Gcm)"
                   @onchange="() => _mode = EncryptMode.Gcm" />
            <label class="form-check-label" for="gcm">Encrypt med RSA/AES i GCM mode</label>
        </div>
    </div>

    <InputFile OnChange="OnFileSelected" class="form-control mb-3" />

    @if (_selectedFile != null)
    {
        <p class="text-muted small">Valgt: <strong>@_selectedFile.Name</strong> (@FormatSize(_selectedFile.Size))</p>
    }

    <button class="btn btn-primary"
            @onclick="SendFile"
            disabled="@(_sending || _selectedFile == null)">
        @if (_sending)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
            <span>Sender...</span>
        }
        else
        {
            <span>Send fil</span>
        }
    </button>
</div>

@code {
    private enum EncryptMode { Rsa, Gcm }

    private IBrowserFile? _selectedFile;
    private bool          _sending;
    private string?       _statusMessage;
    private string        _statusClass = "alert-success";
    private EncryptMode   _mode        = EncryptMode.Rsa;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile  = e.File;
        _statusMessage = null;
    }

    private async Task SendFile()
    {
        if (_selectedFile == null) return;

        _sending       = true;
        _statusMessage = null;

        try
        {
            // Læs fil til memory — aldrig til disk
            const long MaxBytes = 50 * 1024 * 1024;
            await using var stream = _selectedFile.OpenReadStream(MaxBytes);
            using var ms           = new MemoryStream();
            await stream.CopyToAsync(ms);
            byte[] fileBytes = ms.ToArray();

            string publicKey = await AesHandler.FetchAndVerifyPublicKeyAsync();

            string result = _mode == EncryptMode.Rsa
                ? await AesHandler.EncryptAndSendAsync(fileBytes, _selectedFile.Name, publicKey)
                : await AesGcmHandler.EncryptAndSendAsync(fileBytes, _selectedFile.Name, publicKey);

            _statusMessage = "Upload successful! Receiver return message: No contamination detected ✅";
            _statusClass   = "alert-success";
            _selectedFile  = null;
        }
        catch (CryptographicException ex)
        {
            _statusMessage = $"Sikkerhedsfejl: {ex.Message}";
            _statusClass   = "alert-danger";
        }
        catch (Exception ex)
        {
            _statusMessage = $"Fejl: {ex.Message}";
            _statusClass   = "alert-danger";
        }
        finally
        {
            _sending = false;
        }
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024        => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _             => $"{bytes / 1024.0 / 1024.0:F1} MB"
    };
}
